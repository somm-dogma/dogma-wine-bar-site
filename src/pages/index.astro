---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";
import { sommelier } from "../data/home";
import { Image } from "astro:assets";
// Hero — brand logo + storefront
import dogmaLogo from "../assets/images/dogma-logo.png";
// Vasilii / sommelier
import vasiliiPortrait from "../assets/images/DSC00579.jpg";
import vasiliiPalmela from "../assets/images/vasilii-palmela.jpg";
import bronzeMedal from "../assets/images/award-bronze-2024.jpg";
// Intro — storefront
import storefront from "../assets/images/dogma-8.jpeg";
// Master of Port — cellar + IVDP seal
import portCellar from "../assets/images/mop-cellar-bg.jpg";
import mopSealIvdp from "../assets/images/mop-seal-ivdp.png";
import mopSeal from "../assets/images/mop-seal-ivdp.png";
// Services
import svcWineTasting from "../assets/images/dogma-47.jpeg";
import svcPortPour from "../assets/images/DSC09701.jpeg";
// Visit section interior
import momInterior from "../assets/images/IMG_9010.jpeg";
// Moments gallery (editorial wall)
import gFounders from "../assets/images/moment-founders.jpg";
import gTeam from "../assets/images/moment-team.jpg";
import gRoomGold from "../assets/images/moment-room-gold.jpg";
import gPetiscos from "../assets/images/moment-petiscos.jpg";
import gServe from "../assets/images/moment-serve.jpg";
import gCheers from "../assets/images/moment-cheers.jpg";
import gPolvo from "../assets/images/moment-polvo.jpg";
import gTerrace from "../assets/images/moment-terrace.jpg";
import gClams from "../assets/images/moment-clams-bw.jpg";
import gBanquette from "../assets/images/moment-banquette.jpg";
import gCommunal from "../assets/images/moment-communal.jpg";
import gFriends from "../assets/images/moment-friends.jpg";
import gCandid from "../assets/images/moment-candid.jpg";
import gLongTable from "../assets/images/moment-longtable.jpg";
import gDoorway from "../assets/images/moment-doorway.jpg";
import gBottles from "../assets/images/moment-bottles.jpg";
import gFullHouse from "../assets/images/moment-fullhouse.jpg";

// Curated order for the masonry wall — alternates people / food / room, portrait / landscape
const momentsGallery = [
  { src: gTeam, alt: "The Dogma team outside the wine bar" },
  { src: gPetiscos, alt: "A spread of petiscos — sardine toast, charcuterie and olives" },
  { src: gRoomGold, alt: "The dining room full of guests under warm pendant light" },
  { src: gBanquette, alt: "Friends gathered at the colourful banquette" },
  { src: gFounders, alt: "The founders with bottles of sept by the Porto Vintage Classics mural" },
  { src: gPolvo, alt: "A plate of octopus served at the table" },
  { src: gFullHouse, alt: "A full house on a busy evening at Dogma" },
  { src: gTerrace, alt: "A couple toasting at the outdoor terrace table" },
  { src: gServe, alt: "A server pouring wine for guests" },
  { src: gClams, alt: "Clams, bread and olives in black and white" },
  { src: gCandid, alt: "Guests sharing wine and plates around the table" },
  { src: gDoorway, alt: "The doorway of Dogma, established May 2023" },
  { src: gCommunal, alt: "A communal dinner along the long table" },
  { src: gFriends, alt: "A group of friends raising a glass together" },
  { src: gBottles, alt: "Bottles lined along the bar above the banquette" },
  { src: gLongTable, alt: "An evening tasting along the long communal table" },
];
// Credentials & affiliations (round pin symbols)
import credAssoc from "../assets/images/cred-assoc-escancoes.png";
import credCertSomm from "../assets/images/cred-certified-sommelier.jpg";
import credAsi from "../assets/images/cred-asi.png";
import credStarRed from "../assets/images/cred-star-red.png";
import credStarSilver from "../assets/images/cred-star-silver.png";
import credShield from "../assets/images/cred-sommelier-venue-shield.png";

const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
  `${site.contact.address}, ${site.contact.postalCode} ${site.contact.city}`
)}`;
---

<Base>
  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="hero">
    <!-- full-bleed background photo -->
    <figure class="hero__photo" aria-hidden="true">
      <Image
        src={storefront}
        alt=""
        widths={[800, 1300, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </figure>

    <!-- content panel floats above with gradient veil -->
    <div class="hero__panel">
      <div class="hero__panel-inner">
        <h1 class="hero__logo-h1">
          <span class="hero__seal">
            <Image
              src={dogmaLogo}
              alt="Dogma — Wine Bar &amp; Tastings, Porto"
              class="hero__logo"
              widths={[320, 520, 720]}
              sizes="(max-width: 880px) 200px, 280px"
              loading="eager"
            />
          </span>
        </h1>
        <span class="hero__rule" aria-hidden="true"></span>
        <p class="hero__tagline">{site.tagline}</p>
        <div class="hero__cta">
          <a class="btn btn--cream" href={site.booking.tasting}>Book a tasting</a>
          <a class="btn btn--ghost" href={site.booking.table}>Book a table</a>
        </div>
        <p class="hero__place">Rua dos Caldeireiros 238 · Porto</p>
      </div>
    </div>

    <a class="hero__scroll" href="#intro" aria-label="Scroll to content">↓</a>
  </section>

  <!-- ───────────────────────── INTRO ───────────────────────── -->
  <section class="section intro" id="intro">
    <div class="container intro__inner">
      <div class="intro__text" data-reveal="left">
        <p class="eyebrow eyebrow--ink">The Place</p>
        <h2 class="intro__title">A wine paradise in the heart of Porto.</h2>
        <p class="lead">
          Since 2023, Dogma has become one of the city’s most talked-about wine bars — a place to
          slow down, taste widely, and let the terroir speak.
        </p>
      </div>
      <figure class="media intro__media" data-reveal="right">
        <Image
          src={gCheers}
          alt="Friends toasting with glasses of wine over a table of petiscos at Dogma"
          widths={[400, 700, 920]}
          sizes="(max-width: 880px) 460px, 40vw"
        />
      </figure>
    </div>
  </section>

  <!-- ──────────────────── MASTER OF PORT (spine) ──────────────────── -->
  <section class="section mop">
    <Image
      src={portCellar}
      alt=""
      class="mop__bg"
      aria-hidden="true"
      widths={[768, 1280, 1800]}
      sizes="100vw"
    />
    <div class="container mop__inner" data-reveal="scale">
      <figure class="mop__seal">
        <Image src={mopSeal} alt="Douro e Porto — Garantia, since 1756 (IVDP seal)" widths={[200, 400]} sizes="180px" />
      </figure>
      <p class="eyebrow">The credential</p>
      <h2 class="mop__title">The first Master of Port in Portugal.</h2>
      <p class="mop__body">
        The Master of Port is the highest distinction awarded for Port wine expertise. Vasilii
        Grebencea is the first in Portugal to hold it — and one of the country’s top three
        sommeliers. It means every tasting at Dogma is led by someone who has reached the very top of
        his craft, and who pours it as a conversation rather than a lecture.
      </p>
      <a class="btn btn--cream" href={site.booking.tasting}>Taste with a Master of Port</a>
    </div>
  </section>

  <!-- ───────────────────────── RECOGNITION ───────────────────────── -->
  <section class="section proud">
    <div class="container">
      <header class="section-head center" data-reveal>
        <p class="eyebrow eyebrow--ink">Recognition</p>
        <h2>A young bar, already noticed.</h2>
      </header>

      <div class="proud__layout">
        <figure class="media proud__media" data-reveal="left">
          <Image
            src={vasiliiPalmela}
            alt="Vasilii Grebencea assessing a glass on stage at the National Sommelier Championship"
            widths={[420, 760, 1100]}
            sizes="(max-width: 1024px) 100vw, 40vw"
          />
          <figcaption class="proud__caption">Concurso Nacional de Escanções</figcaption>
        </figure>

        <div class="proud__grid" data-reveal="right">
          <article class="award" data-reveal style="--reveal-delay: 60ms">
            <p class="award__figure">Top 6</p>
            <p class="award__text">Shortlisted worldwide for Best Newcomer — Star Wine List of the Year 2024.</p>
          </article>
          <article class="award" data-reveal style="--reveal-delay: 120ms">
            <p class="award__figure">1<sup class="award__sup">st</sup></p>
            <p class="award__text">First in Portugal on Star Wine List — three consecutive years with a Red Star.</p>
          </article>
          <a
            class="award award--link"
            href="/certificates/ambassador-porto-2025-2028.pdf"
            target="_blank"
            rel="noopener"
            data-reveal
            style="--reveal-delay: 180ms"
          >
            <span class="award__figure">2025–28</span>
            <span class="award__text">Official Ambassador of Porto, Sommelier Association of Portugal. <span class="award__view">View certificate →</span></span>
          </a>
        </div>
      </div>

      <!-- Honours: bronze medal + Star Wine List Red Star years -->
      <div class="honours">
        <a
          class="honour-medal"
          href={bronzeMedal.src}
          target="_blank"
          rel="noopener"
          data-reveal="left"
          aria-label="Bronze Medal, 3rd best sommelier in Portugal, 2024 — open photo"
        >
          <figure class="honour-medal__fig media">
            <Image
              src={bronzeMedal}
              alt="Bronze medal trophy — XIX Concurso Nacional de Escanções 2024"
              widths={[360, 640, 900]}
              sizes="(max-width: 760px) 100vw, 38vw"
            />
          </figure>
          <figcaption class="honour-medal__cap">
            <span class="honour-medal__rank">Bronze Medal · 2024</span>
            <span class="honour-medal__desc">3rd Best Sommelier in Portugal — XIX Concurso Nacional de Escanções</span>
          </figcaption>
        </a>

        <div class="swl" data-reveal="right">
          <p class="swl__title">Star Wine List · Red Star</p>
          <p class="swl__sub">Red Star three consecutive years among the world’s great wine lists.</p>
          <div class="swl__row">
            {[2024, 2025, 2026].map((yr) => (
              <a
                class="swl__badge"
                href="https://starwinelist.com/wine-place/dogma-wine-bar?utm_source=badge&utm_content=large"
                target="_blank"
                rel="noopener"
                title={`Star Wine List — Dogma Wine Bar, Red Star ${yr}`}
              >
                <span class="swl__badgewrap">
                  <img
                    src="https://starwinelist.com/img/badges/large.png"
                    srcset="https://starwinelist.com/img/badges/large2x.png 2x, https://starwinelist.com/img/badges/large3x.png 3x"
                    width="100"
                    height="183"
                    loading="lazy"
                    alt={`Star Wine List Red Star badge, Dogma Wine Bar, ${yr}`}
                  />
                  <span class="swl__yr">{yr}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Credentials & affiliations -->
      <div class="creds" data-reveal>
        <p class="creds__title">Credentials &amp; affiliations</p>

        <!-- Flagship venue credential — its own badge -->
        <a
          class="venue-badge"
          href="/certificates/certified-sommelier-venue.pdf"
          target="_blank"
          rel="noopener"
          aria-label="Certified Sommelier Venue — Associação dos Escanções de Portugal · Wines of Portugal. Open the official plaque."
        >
          <Image src={credShield} alt="Estabelecimento com Escanção Sommelier — official certified sommelier venue plaque" widths={[260, 420]} sizes="220px" />
          <span class="venue-badge__cap">Certified Sommelier Venue<br /><span class="venue-badge__sub">Escanções de Portugal · Wines of Portugal</span></span>
        </a>

        <ul class="pins">
          <li>
            <span class="pin" title="Associação dos Escanções de Portugal" aria-label="Member, Associação dos Escanções de Portugal">
              <Image src={credAssoc} alt="Associação dos Escanções de Portugal seal" widths={[140, 280]} sizes="116px" />
            </span>
          </li>
          <li>
            <span class="pin" title="ASI — Association de la Sommellerie Internationale (member)" aria-label="ASI — Association de la Sommellerie Internationale, member">
              <Image src={credAsi} alt="ASI member seal" widths={[140, 280]} sizes="116px" />
            </span>
          </li>
          <li>
            <span class="pin pin--inset" title="Certified sommelier" aria-label="Certified sommelier">
              <Image src={credCertSomm} alt="Certified sommelier emblem" widths={[160, 320]} sizes="116px" />
            </span>
          </li>
          <li>
            <span class="pin" title="Star Wine List — Red Star" aria-label="Star Wine List, Red Star">
              <Image src={credStarRed} alt="Star Wine List red star" widths={[140, 280]} sizes="116px" />
            </span>
          </li>
          <li>
            <span class="pin" title="Silver Star — Star Wine List of the Year 2024" aria-label="Silver Star, Star Wine List of the Year 2024">
              <Image src={credStarSilver} alt="Silver Star, Star Wine List of the Year 2024" widths={[140, 280]} sizes="116px" />
            </span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── SOMMELIER ───────────────────────── -->
  <section class="section somm">
    <div class="container somm__inner">
      <div class="somm__body" data-reveal="left">
        <p class="eyebrow">Author’s note</p>
        <blockquote class="somm__quote">{sommelier.quote}</blockquote>
        <p class="somm__name">{sommelier.name}</p>
        <p class="somm__role">{sommelier.role}</p>
        <a class="btn btn--cream" href="/sommelier">Meet Vasilii</a>
      </div>

      <!-- Vasilii portrait — Master of Port -->
      <figure class="crest" aria-label="Vasilii Grebencea, Master of Port" data-reveal="right">
        <Image
          src={vasiliiPortrait}
          alt="Vasilii Grebencea presenting at a wine event"
          class="crest__image"
          widths={[400, 720, 1040]}
          sizes="(max-width: 880px) 360px, 38vw"
        />
        <p class="crest__name">Vasilii Grebencea</p>
        <p class="crest__title">Master of Port · Porto</p>
        <span class="crest__star" aria-hidden="true">✶</span>
      </figure>
    </div>
  </section>

  <!-- ───────────────────────── SERVICES (live only) ───────────────────────── -->
  <section class="section services" id="services">
    <div class="container">
      <header class="section-head center" data-reveal>
        <p class="eyebrow eyebrow--ink">What we offer</p>
        <h2>Two ways to taste.</h2>
      </header>
      <div class="services__grid">
        <article class="svc" data-reveal="scale" style="--reveal-delay: 0ms">
          <figure class="media svc__media">
            <Image
              src={svcWineTasting}
              alt="Guests tasting Portuguese wine at Dogma"
              widths={[400, 600, 900]}
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          </figure>
          <div class="svc__body">
            <h2 class="svc__title">Wine Tasting</h2>
            <p class="svc__text">
              A guided flight through the best of Portugal — five or six wines, the stories behind
              them, and the terroir in the glass.
            </p>
            <p class="svc__price">From €45 · 90 min</p>
            <a class="btn btn--primary" href={site.booking.tasting}>Book a tasting</a>
          </div>
        </article>
        <article class="svc" data-reveal="scale" style="--reveal-delay: 120ms">
          <figure class="media svc__media">
            <Image
              src={svcPortPour}
              alt="Port wine being poured into a tasting glass"
              widths={[400, 600, 900]}
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          </figure>
          <div class="svc__body">
            <h2 class="svc__title">Port Wine Tasting</h2>
            <p class="svc__text">
              A masterclass in Port led by a Master of Port — vintage, tawny and white, with rare
              bottles from the cellar.
            </p>
            <p class="svc__price">From €65 · 120 min</p>
            <a class="btn btn--primary" href={site.booking.tasting}>Book a tasting</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── MOMENTS (editorial gallery) ───────────────────────── -->
  <section class="section moments" id="moments">
    <div class="container">
      <header class="section-head center" data-reveal>
        <p class="eyebrow eyebrow--ink">Moments</p>
        <h2>An evening at Dogma.</h2>
      </header>
      <div class="moments__wall">
        {momentsGallery.map((m, i) => (
          <figure class="mw__item" data-reveal="scale" style={`--reveal-delay: ${(i % 4) * 70}ms`}>
            <Image
              src={m.src}
              alt={m.alt}
              widths={[320, 540, 760]}
              sizes="(max-width: 680px) 45vw, (max-width: 1024px) 30vw, 22vw"
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── VISIT ───────────────────────── -->
  <section class="section visit">
    <div class="container visit__inner">
      <div class="visit__info" data-reveal="left">
        <div class="visit__col">
          <p class="eyebrow">Visit</p>
          <h2 class="visit__title">Pull up a seat.</h2>
          <p class="visit__addr">
            {site.contact.address}<br />
            {site.contact.postalCode} {site.contact.city}, {site.contact.country}
          </p>
          <a class="visit__maps" href={mapsHref} target="_blank" rel="noopener">Open in Google Maps →</a>
        </div>
        <div class="visit__col">
          <p class="eyebrow">Hours</p>
          <ul class="visit__hours">
            {site.hours.map((h) => (
              <li><span>{h.days}</span><span>{h.time}</span></li>
            ))}
          </ul>
          <p class="visit__phone">
            <a href={site.contact.phoneHref}>{site.contact.phone}</a>
          </p>
          <a class="btn btn--cream" href={site.booking.table}>Book a table</a>
        </div>
      </div>
      <figure class="media visit__media" data-reveal="right">
        <Image
          src={momInterior}
          alt="The dining room of Dogma, ready for the evening"
          widths={[500, 800, 1100]}
          sizes="(max-width: 880px) 100vw, 48vw"
        />
      </figure>
    </div>
  </section>

  <!-- ───────────────────────── FINAL CTA ───────────────────────── -->
  <section class="cta">
    <div class="container cta__inner" data-reveal="scale">
      <h2 class="cta__title">Want to learn about wine?</h2>
      <p class="cta__text">
        Spend an evening with Portugal’s first Master of Port. Limited seats at each signature tasting.
      </p>
      <a class="btn btn--cream" href={site.booking.tasting}>Book a tasting</a>
    </div>
  </section>
</Base>

<script>
  // Scroll-reveal via IntersectionObserver. Honors reduced-motion by
  // revealing everything immediately and skipping the observer.
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const items = document.querySelectorAll<HTMLElement>("[data-reveal]");

  if (prefersReduced || !("IntersectionObserver" in window)) {
    items.forEach((el) => el.classList.add("is-visible"));
  } else {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
    );
    items.forEach((el) => observer.observe(el));
  }
</script>

<style>
  /* ───────── HERO (logo panel + storefront) ───────── */
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }
  /* full-bleed background photo */
  .hero__photo {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }
  /* content panel — left half, gradient veil fading to transparent right */
  .hero__panel {
    position: relative;
    z-index: 1;
    width: clamp(320px, 46vw, 580px);
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: clamp(2rem, 5vw, 4rem) clamp(2rem, 5vw, 5rem);
    background: linear-gradient(
      to right,
      rgba(43, 10, 17, 0.96) 0%,
      rgba(43, 10, 17, 0.88) 55%,
      rgba(43, 10, 17, 0.4) 82%,
      transparent 100%
    );
    color: var(--cream-50);
  }
  .hero__panel-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 400px;
  }
  .hero__logo-h1 { margin: 0; line-height: 0; }
  .hero__seal {
    position: relative;
    display: grid;
    place-items: center;
    width: clamp(220px, 26vw, 340px);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1.5px solid var(--gold);
    box-shadow: var(--shadow-xl);
  }
  /* inner concentric ring — seal detailing */
  .hero__seal::before {
    content: "";
    position: absolute;
    inset: 9px;
    border-radius: 50%;
    border: 1px solid rgba(201, 168, 106, 0.5);
    pointer-events: none;
  }
  .hero__logo { width: 68%; height: auto; }
  .hero__rule {
    width: 60px;
    height: 2px;
    background: var(--gold);
    opacity: 0.85;
    margin: clamp(1.5rem, 3.5vw, 2.4rem) 0 clamp(1.1rem, 2.5vw, 1.6rem);
  }
  .hero__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-1);
    line-height: 1.4;
    color: rgba(251, 246, 236, 0.92);
    max-width: 26ch;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
    margin-top: clamp(1.7rem, 3.5vw, 2.4rem);
  }
  .hero__place {
    margin-top: clamp(1.8rem, 4vw, 2.8rem);
    font-size: var(--step--1);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(251, 246, 236, 0.5);
  }
  .hero__scroll {
    position: absolute;
    z-index: 2;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.4rem;
    color: var(--cream-50);
    opacity: 0.65;
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 8px); }
  }
  @media (max-width: 880px) {
    .hero { min-height: 100svh; }
    .hero__panel {
      width: 100%;
      min-height: 100svh;
      justify-content: center;
      padding-top: calc(var(--header-h) + clamp(1.5rem, 6vw, 3rem));
      padding-bottom: clamp(3rem, 10vw, 4.5rem);
      background: linear-gradient(
        to bottom,
        rgba(43, 10, 17, 0.82) 0%,
        rgba(43, 10, 17, 0.72) 60%,
        rgba(43, 10, 17, 0.6) 100%
      );
    }
    .hero__panel-inner { max-width: 360px; }
    .hero__scroll { display: none; }
  }

  /* ───────── INTRO ───────── */
  .intro__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4.5rem);
