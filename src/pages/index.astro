---
import Base from "../layouts/Base.astro";
import OrientalArch from "../components/OrientalArch.astro";
import SunDecorator from "../components/SunDecorator.astro";
import { site } from "../data/site";
import { awards, sommelier, services, wineries, posts } from "../data/home";

const heroImg = "https://optim.tildacdn.net/tild3331-3832-4433-b962-656337323632/-/format/webp/dashakosha_Douro_Val.png.webp";
const fmtDate = (d: string) => new Date(d).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
---

<Base>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- HERO SECTION -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg" style={`background-image:url('${heroImg}')`}></div>

    <div class="hero__decoration hero__decoration--top-left">
      <span class="hero__label">SINCE {site.established}</span>
    </div>
    <div class="hero__decoration hero__decoration--top-right">
      <span class="hero__label">MEMBER OF<br/>STARWINELIST</span>
    </div>

    <div class="hero__content">
      <h1 class="hero__title">WINE BAR<br/>DOGMA</h1>
      <p class="hero__description">{site.tagline}</p>
    </div>

    <div class="hero__buttons">
      <a class="hero__btn hero__btn--left" href={site.booking.tasting}>book a tasting</a>
      <a class="hero__btn hero__btn--right" href={site.booking.table}>book a table</a>
    </div>

    <a class="hero__scroll" href="#section-manifesto" aria-label="Scroll to content">↓</a>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- MANIFESTO SECTION: "DOGMA IS VASILY'S HOME & CREATIVE STUDIO" -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section manifesto" id="section-manifesto">
    <div class="container manifesto__inner">
      <h2 class="manifesto__title">
        DOGMA IS<br/>
        <span class="manifesto__highlight">VASILY'S HOME</span><br/>
        & CREATIVE STUDIO
      </h2>

      <p class="manifesto__description">
        Discover the amazing world of wine at Dogma, a "wine paradise" located in the heart of Porto's historic center
      </p>

      <div class="manifesto__badges">
        <OrientalArch
          badge={true}
          badgeText="STAR WINE LIST"
          badgeYear="2024"
          title="2024"
        />
        <OrientalArch
          badge={true}
          badgeText="STAR WINE LIST"
          badgeYear="2025"
          title="2025"
        />
        <OrientalArch
          badge={true}
          badgeText="STAR WINE LIST"
          badgeYear="2026"
          title="2026"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- PROUD SECTION -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section proud">
    <div class="container proud__inner">
      <div class="proud__header">
        <SunDecorator size="large" color="cream" />
        <h2 class="proud__title">We are proud</h2>
        <SunDecorator size="large" color="cream" />
      </div>

      <p class="proud__text">
        In its short existence, Dogma has already achieved great success, made a name among top wine bars,
        joined the wine community, and is talked about by wine connoisseurs.
      </p>

      <div class="proud__medals">
        <div class="proud__medal">
          <OrientalArch badge={true} badgeText="" badgeYear="">
            <p class="proud__number">1</p>
            <p class="proud__medal-text">member of the highly respected StarWineList in Portugal</p>
          </OrientalArch>
        </div>

        <div class="proud__medal">
          <OrientalArch badge={true} badgeText="" badgeYear="">
            <p class="proud__number">6</p>
            <p class="proud__medal-text">ranked among the World's top 6 winebars as a Startup</p>
          </OrientalArch>
        </div>

        <div class="proud__medal">
          <OrientalArch badge={true} badgeText="" badgeYear="">
            <p class="proud__number">2</p>
            <p class="proud__medal-text">twice nominated for "Wine experience" of the year by Great Wine Capitals</p>
          </OrientalArch>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- AUTHOR'S QUOTE: VASILII -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section author">
    <div class="container author__inner">
      <div class="author__content">
        <div class="author__header">
          <SunDecorator size="medium" color="cream" />
          <p class="author__label">Author's quote</p>
          <SunDecorator size="medium" color="cream" />
        </div>

        <blockquote class="author__quote">
          Hello, I'm Vasilii, head sommelier and owner of Dogma.<br/>
          I am the first Port Wine Master in Portugal and one of the country's top 3 sommeliers.<br/>
          I host signature tastings in Porto.
        </blockquote>

        <p class="author__name">{sommelier.name}</p>
        <p class="author__role">{sommelier.role}</p>

        <a class="author__btn" href={site.booking.tasting}>book a tasting</a>
      </div>

      <div class="author__image">
        <!-- Placeholder - would be Vasilii's photo -->
        <div class="author__image-placeholder">
          <p class="author__image-label">Vasilii's Portrait</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- CHECK IT OUT SECTION -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section checkout">
    <div class="container checkout__inner">
      <h2 class="checkout__title">CHECK IT OUT</h2>

      <div class="checkout__content">
        <div class="checkout__circle">
          <!-- This would be the circular image of the store -->
          <div class="checkout__circle-placeholder">
            <p>Store Image</p>
          </div>
        </div>

        <div class="checkout__features">
          <p class="checkout__feature">Personalized approach</p>
          <p class="checkout__feature">Wine pairing</p>
          <p class="checkout__feature">Portuguese wines</p>
          <p class="checkout__feature">Port wines</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- SERVICES SECTION -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section services" id="services">
    <div class="container services__inner">
      <div class="services__header">
        <p class="services__label">Our services</p>
      </div>

      <div class="services__list">
        <div class="service-item">
          <p class="service__subtitle">CAREFUL SELECTION OF "THE BEST" OF PORTUGAL</p>
          <h3 class="service__title">WINE TASTING</h3>
        </div>

        <div class="service-item">
          <p class="service__subtitle">BEST SELECTION FROM MASTER OF PORT</p>
          <h3 class="service__title">PORT WINE TASTING</h3>
        </div>

        <div class="service-item">
          <p class="service__subtitle">AUTHENTIC TREASURES</p>
          <h3 class="service__title">WINE BOXES</h3>
        </div>

        <div class="service-item">
          <p class="service__subtitle">WHAT COULD BE BETTER?</p>
          <h3 class="service__title">GIFT CARDS</h3>
        </div>

        <div class="service-item">
          <p class="service__subtitle">AN UNFORGETTABLE EXPERIENCE</p>
          <h3 class="service__title">WINE TOURS</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- BLOG SECTION -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section blog" id="blog">
    <div class="container blog__inner">
      <div class="blog__header">
        <SunDecorator size="medium" color="cream" />
        <h2 class="blog__title">Our blog</h2>
        <SunDecorator size="medium" color="cream" />
      </div>

      <div class="blog__grid">
        {posts.map((post) => (
          <div class="blog__post">
            <OrientalArch badge={true} badgeText="">
              <div class="blog__post-image-placeholder">
                <p>{post.title}</p>
              </div>
            </OrientalArch>

            <p class="blog__post-date">{fmtDate(post.date)}</p>
            <h3 class="blog__post-title">{post.title}</h3>
            <p class="blog__post-excerpt">{post.excerpt}</p>
            <a class="blog__post-link" href="#">READ MORE</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- FOOTER -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <footer class="site-footer">
    <div class="footer__backdrop">
      <h2 class="footer__logo">DOGMA</h2>
    </div>

    <div class="container footer__content">
      <div class="footer__col footer__col--dogma">
        <h4 class="footer__heading">DOGMA</h4>
        <p class="footer__tagline">{site.tagline}</p>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">SERVICES</h4>
        <ul class="footer__list">
          <li><a href="/menu">menu</a></li>
          <li><a href={site.booking.tasting}>wine tastings</a></li>
          <li><a href={site.booking.tasting}>port wine tastings</a></li>
          <li><a href="/coming">wine boxes</a></li>
          <li><a href="/coming">wine tours</a></li>
          <li><a href="/coming">gift cards</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">COMPANY</h4>
        <ul class="footer__list">
          <li><a href="/#section-manifesto">about</a></li>
          <li><a href="/sommelier">sommelier</a></li>
          <li><a href="/#blog">blog</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">CONTACTS</h4>
        <ul class="footer__list">
          <li><a href="https://maps.google.com/?q={site.contact.address}">{site.contact.address}</a></li>
          <li><a href={site.contact.phoneHref}>{site.contact.phone}</a></li>
          <li><a href="/contacts">contact us</a></li>
        </ul>
      </div>
    </div>

    <div class="container footer__bottom">
      <p>© {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      <p>Design by <a href={site.credits.designerUrl} target="_blank" rel="noopener">{site.credits.designer}</a></p>
      <p><a href="/privacy">Polite privacy</a></p>
    </div>
  </footer>
</Base>

<style>
  /* ════════════════════════════════════════════════════════════════ */
  /* HERO */
  /* ════════════════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: var(--cream-50);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-size: cover;
    background-position: center;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to top,
      rgba(107, 15, 26, 0.92) 0%,
      rgba(107, 15, 26, 0.4) 40%,
      rgba(107, 15, 26, 0.3) 100%
    );
  }

  .hero__decoration {
    position: absolute;
    z-index: 10;
  }

  .hero__decoration--top-left {
    top: 2rem;
    left: 2rem;
  }

  .hero__decoration--top-right {
    top: 2rem;
    right: 2rem;
    text-align: right;
  }

  .hero__label {
    font-family: var(--font-body);
    font-size: clamp(0.7rem, 1.5vw, 0.9rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(250, 245, 234, 0.75);
    font-weight: 400;
    line-height: 1.4;
  }

  .hero__content {
    position: relative;
    z-index: 5;
    text-align: center;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 12rem);
    font-weight: 600;
    letter-spacing: 0.05em;
    line-height: 0.95;
    margin: 0;
    text-transform: uppercase;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.4);
  }

  .hero__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.4rem);
    margin-top: clamp(1.5rem, 3vh, 2.5rem);
    max-width: 70ch;
    margin-left: auto;
    margin-right: auto;
    color: rgba(250, 245, 234, 0.85);
    font-weight: 300;
    line-height: 1.6;
  }

  .hero__buttons {
    position: absolute;
    z-index: 10;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 clamp(1rem, 4vw, 3rem);
    bottom: clamp(2rem, 8vh, 4rem);
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: clamp(0.9rem, 1.5vw, 1.2rem) clamp(1.5rem, 3vw, 2.5rem);
    background: var(--cream-50);
    color: var(--wine-900);
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    font-weight: 500;
    text-decoration: none;
    border-radius: 50px;
    letter-spacing: 0.05em;
    text-transform: lowercase;
    transition: all 0.3s ease;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .hero__btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  }

  .hero__scroll {
    position: absolute;
    bottom: clamp(1rem, 3vh, 2rem);
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.8rem;
    color: rgba(250, 245, 234, 0.6);
    text-decoration: none;
    opacity: 0.8;
    animation: bob 2.5s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(12px); }
  }

  /* ════════════════════════════════════════════════════════════════ */
  /* MANIFESTO SECTION */
  /* ════════════════════════════════════════════════════════════════ */
  .manifesto {
    background: var(--wine-900);
    color: var(--cream-50);
    padding-block: clamp(3rem, 8vw, 6rem);
  }

  .manifesto__inner {
    text-align: center;
    max-width: 1000px;
  }

  .manifesto__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .manifesto__highlight {
    color: var(--gold-300);
  }

  .manifesto__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.2rem);
    max-width: 60ch;
    margin: 0 auto clamp(2rem, 4vw, 3.5rem);
    line-height: 1.7;
    color: rgba(250, 245, 234, 0.85);
  }

  .manifesto__badges {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: clamp(2rem, 4vw, 3rem);
    justify-items: center;
  }

  /* ════════════════════════════════════════════════════════════════ */
  /* PROUD SECTION */
  /* ════════════════════════════════════════════════════════════════ */
  .proud {
    background: var(--wine-900);
    color: var(--cream-50);
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .proud__inner {
    text-align: center;
    max-width: 1200px;
  }

  .proud__header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2vw, 2rem);
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .proud__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    margin: 0;
  }

  .proud__text {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    max-width: 80ch;
    margin: 0 auto clamp(2.5rem, 5vw, 4rem);
    line-height: 1.6;
    color: rgba(250, 245, 234, 0.85);
    font-style: italic;
  }

  .proud__medals {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: clamp(2rem, 4vw, 3.5rem);
    justify-items: center;
  }

  .proud__number {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    margin: 0;
    color: var(--cream-50);
  }

  .proud__medal-text {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.2vw, 0.95rem);
    color: rgba(250, 245, 234, 0.8);
    line-height: 1.5;
    margin-top: 1rem;
  }

  /* ════════════════════════════════════════════════════════════════ */
  /* AUTHOR SECTION */
  /* ════════════════════════════════════════════════════════════════ */
  .author {
    background: var(--wine-900);
    color: var(--cream-50);
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .author__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: center;
  }

  .author__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .author__label {
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-300);
  }

  .author__quote {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    line-height: 1.5;
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem) 0;
    color: var(--cream-50);
  }

  .author__name {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 600;
    margin: 0 0 0.3rem;
    color: var(--cream-50);
  }

  .author__role {
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 1.2vw, 0.95rem);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-300);
    margin: 0 0 clamp(1.5rem, 3vw, 2rem);
  }

  .author__btn {
    display: inline-block;
    padding: 0.9rem 2rem;
    border: 2px solid var(--cream-50);
    color: var(--cream-50);
    text-decoration: none;
    border-radius: 50px;
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    text-transform: lowercase;
    transition: all 0.3s ease;
  }

  .author__btn:hover {
    background: var(--cream-50);
    color: var(--wine-900);
  }

  .author__image {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    background: linear-gradient(135deg, #7a1a2a, #5a0f18);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .author__image-placeholder {
    text-align: center;
    color: rgba(250, 245, 234, 0.5);
  }

  @media (max-width: 880px) {
    .author__inner {
      grid-template-columns: 1fr;
    }
  }

  /* ════════════════════════════════════════════════════════════════ */
  /* CHECKOUT SECTION */
  /* ════════════════════════════════════════════════════════════════ */
  .checkout {
    background: var(--cream-50);
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .checkout__inner {
    text-align: center;
  }

  .checkout__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    color: var(--wine-900);
    font-weight: 600;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .checkout__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: center;
  }

  .checkout__circle {
    position: relative;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1;
    margin: 0 auto;
  }

  .checkout__circle-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, #f4ecdb, #fff8e7);
    border: 8px solid var(--wine-900);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--wine-900);
    font-size: 1.2rem;
  }

  .checkout__features {
    text-align: left;
  }

  .checkout__feature {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--wine-900);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 880px) {
    .checkout__content {
      grid-template-columns: 1fr;
    }

    .checkout__features {
      text-align: center;
    }
  }

  /* ════════════════════════════════════════════════════════════════ */
  /* SERVICES SECTION */
  /* ════════════════════════════════════════════════════════════════ */
  .services {
    background: var(--wine-900);
    color: var(--cream-50);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .services__inner {
    max-width: 1000px;
  }

  .services__header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .services__label {
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold-300);
  }

  .services__list {
    display: grid;
    gap: 0;
  }

  .service-item {
    padding: clamp(2rem, 4vw, 3rem) 0;
    border-bottom: 1px solid rgba(250, 245, 234, 0.2);
    text-align: center;
  }

  .service-item:last-child {
    border-bottom: none;
  }

  .service__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 1.2vw, 0.95rem);
    text-transform: uppercase;
