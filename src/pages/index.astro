---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";
import { sommelier } from "../data/home";
import { Image } from "astro:assets";
// Hero & landscape
import heroDouro from "../assets/images/5091F715-C8D5-45A5-8FB5-AE0FE20F71BB.jpg";
// Vasilii / sommelier
import vasiliiPortrait from "../assets/images/DSC00579.jpg";
import vasiliiPalmela from "../assets/images/vasilii-palmela.jpg";
import bronzeMedal from "../assets/images/award-bronze-2024.jpg";
// Intro — storefront
import storefront from "../assets/images/dogma-8.jpeg";
// Master of Port — cellar
import portCellar from "../assets/images/IMG_6101.jpeg";
// Services
import svcWineTasting from "../assets/images/dogma-47.jpeg";
import svcPortPour from "../assets/images/DSC09701.jpeg";
// Moments gallery
import momInterior from "../assets/images/IMG_9010.jpeg";
import momGroup from "../assets/images/IMG_5232.jpeg";
import momTerrace from "../assets/images/dogma-52.jpeg";
import momFood from "../assets/images/dogma-55.jpeg";
import momCheers from "../assets/images/dogma-30.jpeg";
import momTram from "../assets/images/7A33A8DD-3ACE-455A-9EF0-DAEDFBD1BE21.jpg";
// Credentials & affiliations (round pin symbols)
import credAssoc from "../assets/images/cred-assoc-escancoes.png";
import credCertSomm from "../assets/images/cred-certified-sommelier.jpg";

const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
  `${site.contact.address}, ${site.contact.postalCode} ${site.contact.city}`
)}`;
---

<Base>
  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="hero">
    <Image
      src={heroDouro}
      alt="Douro Valley terraced vineyards and river"
      class="hero__bg-image"
      loading="eager"
      fetchpriority="high"
      widths={[640, 1024, 1600, 2000]}
      sizes="100vw"
    />
    <div class="hero__bg"></div>

    <span class="hero__corner hero__corner--l">Since {site.established}</span>
    <span class="hero__corner hero__corner--r">Member of<br />Star Wine List</span>

    <div class="container hero__content">
      <p class="hero__eyebrow">Portugal’s first Master of Port</p>
      <p class="hero__credential">The world’s highest Port wine credential, held by only a handful of experts globally</p>
      <h1 class="hero__title">Wine Bar<br />Dogma</h1>
      <p class="hero__sub">{site.tagline}</p>
      <div class="hero__cta">
        <a class="btn btn--cream" href={site.booking.tasting}>Book a tasting</a>
        <a class="btn btn--ghost" href={site.booking.table}>Book a table</a>
      </div>
    </div>

    <a class="hero__scroll" href="#intro" aria-label="Scroll to content">↓</a>
  </section>

  <!-- ───────────────────────── INTRO ───────────────────────── -->
  <section class="section intro" id="intro">
    <div class="container intro__inner">
      <div class="intro__text" data-reveal="left">
        <p class="eyebrow eyebrow--ink">The house</p>
        <h2 class="intro__title">A wine paradise in the heart of Porto.</h2>
        <p class="lead">
          Since 2023, Dogma has become one of the city’s most talked-about wine bars — a place to
          slow down, taste widely, and let the terroir speak, every glass poured under the guidance
          of Portugal’s first Master of Port.
        </p>
        <ul class="intro__facts">
          <li>Established 2023</li>
          <li>Member of Star Wine List, 2024–2026</li>
          <li>Featured in <em>O Escanção</em></li>
        </ul>
      </div>
      <figure class="media intro__media" data-reveal="right">
        <Image
          src={storefront}
          alt="Vasilii at the door of Dogma, established May 2023"
          widths={[400, 700, 920]}
          sizes="(max-width: 880px) 460px, 40vw"
        />
        <figcaption class="intro__caption">Rua dos Caldeireiros 238 · Est. May 2023</figcaption>
      </figure>
    </div>
  </section>

  <!-- ──────────────────── MASTER OF PORT (spine) ──────────────────── -->
  <section class="section mop">
    <Image
      src={portCellar}
      alt=""
      class="mop__bg"
      aria-hidden="true"
      widths={[768, 1280, 1800]}
      sizes="100vw"
    />
    <div class="container mop__inner" data-reveal="scale">
      <div class="mop__seal" aria-hidden="true">
        <svg viewBox="0 0 200 200" role="img">
          <defs>
            <path id="seal-top" d="M100,100 m -70,0 a 70,70 0 1,1 140,0" />
            <path id="seal-bot" d="M100,100 m 70,0 a 70,70 0 1,1 -140,0" />
          </defs>
          <!-- double outer ring -->
          <circle cx="100" cy="100" r="95" fill="none" stroke="currentColor" stroke-width="1.1" />
          <circle cx="100" cy="100" r="89" fill="none" stroke="currentColor" stroke-width="0.5" />
          <!-- circular stamp text -->
          <text class="seal-cap"><textPath href="#seal-top" startOffset="50%" text-anchor="middle">MASTER OF PORT</textPath></text>
          <text class="seal-cap"><textPath href="#seal-bot" startOffset="50%" text-anchor="middle">PORTUGAL · EST. 2023</textPath></text>
          <!-- separator dots where the arcs meet -->
          <circle cx="30" cy="100" r="1.8" fill="currentColor" />
          <circle cx="170" cy="100" r="1.8" fill="currentColor" />
          <!-- inner ring + 8-point star -->
          <circle cx="100" cy="100" r="42" fill="none" stroke="currentColor" stroke-width="0.6" />
          <path
            d="M100,80 L103.25,92.15 L114.14,85.86 L107.85,96.75 L120,100 L107.85,103.25 L114.14,114.14 L103.25,107.85 L100,120 L96.75,107.85 L85.86,114.14 L92.15,103.25 L80,100 L92.15,96.75 L85.86,85.86 L96.75,92.15 Z"
            fill="currentColor"
          />
          <circle cx="100" cy="100" r="1.6" fill="var(--wine-900)" />
        </svg>
      </div>
      <p class="eyebrow">The credential</p>
      <h2 class="mop__title">The first Master of Port in Portugal.</h2>
      <p class="mop__body">
        The Master of Port is the highest distinction awarded for Port wine expertise. Vasilii
        Grebencea is the first in Portugal to hold it — and one of the country’s top three
        sommeliers. It means every tasting at Dogma is led by someone who has reached the very top of
        his craft, and who pours it as a conversation rather than a lecture.
      </p>
      <a class="btn btn--cream" href={site.booking.tasting}>Taste with a Master of Port</a>
    </div>
  </section>

  <!-- ───────────────────────── RECOGNITION ───────────────────────── -->
  <section class="section proud">
    <div class="container">
      <header class="section-head center" data-reveal>
        <p class="eyebrow eyebrow--ink">Recognition</p>
        <h2>A young bar, already noticed.</h2>
      </header>

      <div class="proud__layout">
        <figure class="media proud__media" data-reveal="left">
          <Image
            src={vasiliiPalmela}
            alt="Vasilii Grebencea assessing a glass on stage at the National Sommelier Championship"
            widths={[420, 760, 1100]}
            sizes="(max-width: 1024px) 100vw, 40vw"
          />
          <figcaption class="proud__caption">Concurso Nacional de Escanções</figcaption>
        </figure>

        <div class="proud__grid" data-reveal="right">
          <article class="award" data-reveal style="--reveal-delay: 60ms">
            <p class="award__figure">Top 6</p>
            <p class="award__text">Shortlisted worldwide for Best Newcomer — Star Wine List of the Year 2024.</p>
          </article>
          <article class="award" data-reveal style="--reveal-delay: 120ms">
            <p class="award__figure">1<sup class="award__sup">st</sup></p>
            <p class="award__text">First wine bar in Portugal on Star Wine List — three consecutive years with a Red Star.</p>
          </article>
          <article class="award" data-reveal style="--reveal-delay: 180ms">
            <p class="award__figure">2025–28</p>
            <p class="award__text">Official Ambassador of Porto, Sommelier Association of Portugal.</p>
          </article>
        </div>
      </div>

      <!-- Honours: bronze medal + Star Wine List Red Star years -->
      <div class="honours">
        <a
          class="honour-medal"
          href={bronzeMedal.src}
          target="_blank"
          rel="noopener"
          data-reveal="left"
          aria-label="Bronze Medal, 3rd best sommelier in Portugal, 2024 — open photo"
        >
          <figure class="honour-medal__fig media">
            <Image
              src={bronzeMedal}
              alt="Bronze medal trophy — XIX Concurso Nacional de Escanções 2024"
              widths={[360, 640, 900]}
              sizes="(max-width: 760px) 100vw, 38vw"
            />
          </figure>
          <figcaption class="honour-medal__cap">
            <span class="honour-medal__rank">Bronze Medal · 2024</span>
            <span class="honour-medal__desc">3rd Best Sommelier in Portugal — XIX Concurso Nacional de Escanções</span>
          </figcaption>
        </a>

        <div class="swl" data-reveal="right">
          <p class="swl__title">Star Wine List · Red Star</p>
          <p class="swl__sub">Awarded a Red Star in <strong>2024, 2025 and 2026</strong> — three consecutive years among the world’s great wine lists.</p>
          <div class="swl__row">
            <a
              class="swl__badge"
              href="https://starwinelist.com/wine-place/dogma-wine-bar?utm_source=badge&utm_content=large"
              target="_blank"
              rel="noopener"
              title="Star Wine List — Dogma Wine Bar, Red Star 2026"
            >
              <img
                src="https://starwinelist.com/img/badges/large.png"
                srcset="https://starwinelist.com/img/badges/large2x.png 2x, https://starwinelist.com/img/badges/large3x.png 3x"
                width="100"
                height="183"
                loading="lazy"
                alt="Star Wine List Red Star badge, Dogma Wine Bar, 2026"
              />
              <span class="swl__year">2026</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Credentials & affiliations — symbol pins -->
      <div class="creds" data-reveal>
        <p class="creds__title">Credentials &amp; affiliations</p>
        <ul class="pins">
          <li>
            <span class="pin" title="Associação dos Escanções de Portugal" aria-label="Member, Associação dos Escanções de Portugal">
              <Image src={credAssoc} alt="Associação dos Escanções de Portugal seal" widths={[140, 280]} sizes="110px" />
            </span>
          </li>
          <li>
            <span class="pin pin--inset" title="Certified Sommelier Venue — Associação dos Escanções de Portugal" aria-label="Certified Sommelier Venue">
              <Image src={credCertSomm} alt="Certified sommelier venue mark" widths={[160, 320]} sizes="110px" />
            </span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── SOMMELIER ───────────────────────── -->
  <section class="section somm">
    <div class="container somm__inner">
      <div class="somm__body" data-reveal="left">
        <p class="eyebrow">Author’s note</p>
        <blockquote class="somm__quote">{sommelier.quote}</blockquote>
        <p class="somm__name">{sommelier.name}</p>
        <p class="somm__role">{sommelier.role}</p>
        <a class="btn btn--cream" href="/sommelier">Meet Vasilii</a>
      </div>

      <!-- Vasilii portrait — Master of Port -->
      <figure class="crest" aria-label="Vasilii Grebencea, Master of Port" data-reveal="right">
        <Image
          src={vasiliiPortrait}
          alt="Vasilii Grebencea presenting at a wine event"
          class="crest__image"
          widths={[400, 720, 1040]}
          sizes="(max-width: 880px) 360px, 38vw"
        />
        <p class="crest__name">Vasilii Grebencea</p>
        <p class="crest__title">Master of Port · Porto</p>
        <span class="crest__star" aria-hidden="true">✶</span>
      </figure>
    </div>
  </section>

  <!-- ───────────────────────── SERVICES (live only) ───────────────────────── -->
  <section class="section services" id="services">
    <div class="container">
      <header class="section-head center" data-reveal>
        <p class="eyebrow eyebrow--ink">What we offer</p>
        <h2>Two ways to taste.</h2>
      </header>
      <div class="services__grid">
        <article class="svc" data-reveal="scale" style="--reveal-delay: 0ms">
          <figure class="media svc__media">
            <Image
              src={svcWineTasting}
              alt="Guests tasting Portuguese wine at Dogma"
              widths={[400, 600, 900]}
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          </figure>
          <div class="svc__body">
            <h2 class="svc__title">Wine Tasting</h2>
            <p class="svc__text">
              A guided flight through the best of Portugal — five or six wines, the stories behind
              them, and the terroir in the glass.
            </p>
            <p class="svc__price">From €45 · 90 min</p>
            <a class="btn btn--primary" href={site.booking.tasting}>Book a tasting</a>
          </div>
        </article>
        <article class="svc" data-reveal="scale" style="--reveal-delay: 120ms">
          <figure class="media svc__media">
            <Image
              src={svcPortPour}
              alt="Port wine being poured into a tasting glass"
              widths={[400, 600, 900]}
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          </figure>
          <div class="svc__body">
            <h2 class="svc__title">Port Wine Tasting</h2>
            <p class="svc__text">
              A masterclass in Port led by a Master of Port — vintage, tawny and white, with rare
              bottles from the cellar.
            </p>
            <p class="svc__price">From €65 · 120 min</p>
            <a class="btn btn--primary" href={site.booking.tasting}>Book a tasting</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── MOMENTS (editorial gallery) ───────────────────────── -->
  <section class="section moments" id="moments">
    <div class="container">
      <header class="section-head center" data-reveal>
        <p class="eyebrow eyebrow--ink">Moments</p>
        <h2>An evening at Dogma.</h2>
      </header>
      <div class="moments__grid">
        <figure class="media m-tall" data-reveal="scale" style="--reveal-delay: 0ms">
          <Image src={momInterior} alt="The warm dining room of Dogma under pendant lights" widths={[400, 700, 900]} sizes="(max-width: 768px) 50vw, 33vw" />
        </figure>
        <figure class="media" data-reveal="scale" style="--reveal-delay: 80ms">
          <Image src={momGroup} alt="A group toasting around a long table at Dogma" widths={[350, 600, 800]} sizes="(max-width: 768px) 50vw, 33vw" />
        </figure>
        <figure class="media" data-reveal="scale" style="--reveal-delay: 160ms">
          <Image src={momFood} alt="Petiscos and wine served on the table" widths={[350, 600, 800]} sizes="(max-width: 768px) 50vw, 33vw" />
        </figure>
        <figure class="media m-wide" data-reveal="scale" style="--reveal-delay: 240ms">
          <Image src={momTerrace} alt="Guests toasting on the outdoor terrace" widths={[500, 800, 1100]} sizes="(max-width: 768px) 100vw, 66vw" />
        </figure>
        <figure class="media" data-reveal="scale" style="--reveal-delay: 320ms">
          <Image src={momCheers} alt="A close toast of white wine glasses" widths={[350, 600, 800]} sizes="(max-width: 768px) 50vw, 33vw" />
        </figure>
        <figure class="media" data-reveal="scale" style="--reveal-delay: 400ms">
          <Image src={momTram} alt="The historic Porto tram by the Douro river" widths={[350, 600, 800]} sizes="(max-width: 768px) 50vw, 33vw" />
        </figure>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── VISIT ───────────────────────── -->
  <section class="section visit">
    <div class="container visit__inner">
      <div class="visit__info" data-reveal="left">
        <div class="visit__col">
          <p class="eyebrow">Visit</p>
          <h2 class="visit__title">Pull up a seat.</h2>
          <p class="visit__addr">
            {site.contact.address}<br />
            {site.contact.postalCode} {site.contact.city}, {site.contact.country}
          </p>
          <a class="visit__maps" href={mapsHref} target="_blank" rel="noopener">Open in Google Maps →</a>
        </div>
        <div class="visit__col">
          <p class="eyebrow">Hours</p>
          <ul class="visit__hours">
            {site.hours.map((h) => (
              <li><span>{h.days}</span><span>{h.time}</span></li>
            ))}
          </ul>
          <p class="visit__phone">
            <a href={site.contact.phoneHref}>{site.contact.phone}</a>
          </p>
          <a class="btn btn--cream" href={site.booking.table}>Book a table</a>
        </div>
      </div>
      <figure class="media visit__media" data-reveal="right">
        <Image
          src={momInterior}
          alt="The dining room of Dogma, ready for the evening"
          widths={[500, 800, 1100]}
          sizes="(max-width: 880px) 100vw, 48vw"
        />
      </figure>
    </div>
  </section>

  <!-- ───────────────────────── FINAL CTA ───────────────────────── -->
  <section class="cta">
    <div class="container cta__inner" data-reveal="scale">
      <h2 class="cta__title">Want to learn about wine?</h2>
      <p class="cta__text">
        Spend an evening with Portugal’s first Master of Port. Limited seats at each signature tasting.
      </p>
      <a class="btn btn--cream" href={site.booking.tasting}>Book a tasting</a>
    </div>
  </section>
</Base>

<script>
  // Scroll-reveal via IntersectionObserver. Honors reduced-motion by
  // revealing everything immediately and skipping the observer.
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const items = document.querySelectorAll<HTMLElement>("[data-reveal]");

  if (prefersReduced || !("IntersectionObserver" in window)) {
    items.forEach((el) => el.classList.add("is-visible"));
  } else {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
    );
    items.forEach((el) => observer.observe(el));
  }

  // Subtle hero parallax — transform only, disabled for reduced-motion.
  if (!prefersReduced) {
    const heroImg = document.querySelector<HTMLElement>(".hero__bg-image");
    if (heroImg) {
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const y = Math.min(window.scrollY, window.innerHeight);
          heroImg.style.transform = `scale(1.06) translate3d(0, ${y * 0.12}px, 0)`;
          ticking = false;
        });
      };
      window.addEventListener("scroll", onScroll, { passive: true });
    }
  }
</script>

<style>
  /* ───────── HERO ───────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    color: var(--cream-50);
    padding-block: clamp(7rem, 16vh, 11rem) clamp(3rem, 9vh, 5.5rem);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to top,
      rgba(43, 10, 17, 0.9) 0%,
      rgba(43, 10, 17, 0.34) 52%,
      rgba(43, 10, 17, 0.55) 100%
    );
  }
  .hero__corner {
    position: absolute;
    top: clamp(5.5rem, 11vh, 7rem);
    font-size: var(--step--1);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(251, 246, 236, 0.82);
    line-height: 1.35;
  }
  .hero__corner--l { left: var(--gutter); }
  .hero__corner--r { right: var(--gutter); text-align: right; }
  .hero__content { max-width: 900px; }
  .hero__eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--step-0);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-300);
  }
  .hero__credential {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--step-0);
    letter-spacing: 0.02em;
    color: rgba(251, 246, 236, 0.85);
    margin-block: 0.5em 0.3em;
    max-width: 60ch;
  }
  .hero__title {
    font-size: var(--step-4);
    margin-block: 0.18em 0.4em;
    line-height: 0.95;
    text-wrap: balance;
  }
  .hero__sub {
    font-size: var(--step-1);
    max-width: 48ch;
    color: rgba(251, 246, 236, 0.9);
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 2rem; }
  .hero__scroll {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.4rem;
    opacity: 0.7;
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 8px); }
  }

  /* ───────── INTRO ───────── */
  .intro__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .intro__text { max-width: 60ch; }
  .intro__media {
    aspect-ratio: 4 / 5;
    box-shadow: var(--shadow-lg);
  }
  .intro__media img { object-position: center; }
  .intro__caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 2.2rem 1.2rem 1rem;
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cream-50);
    background: linear-gradient(to top, rgba(43, 10, 17, 0.82), transparent);
    text-align: center;
  }
  .intro__title { font-size: var(--step-3); margin: 0.4em 0 0.5em; text-wrap: balance; }
  .intro__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.4rem;
    margin-top: 1.8rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .intro__facts li {
    position: relative;
    padding-left: 1.1rem;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }
  .intro__facts li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }
  .intro__facts em { font-style: italic; color: var(--ink); }

  /* ───────── MASTER OF PORT ───────── */
  .mop {
    position: relative;
    background: var(--wine-900);
    color: var(--cream-50);
    overflow: hidden;
    isolation: isolate;
  }
  .mop__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.18;
    z-index: -2;
