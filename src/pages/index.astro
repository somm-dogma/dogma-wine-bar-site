---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";
import { sommelier } from "../data/home";

const heroImg =
  "https://optim.tildacdn.net/tild3331-3832-4433-b962-656337323632/-/format/webp/dashakosha_Douro_Val.png.webp";

const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
  `${site.contact.address}, ${site.contact.postalCode} ${site.contact.city}`
)}`;
---

<Base>
  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="hero">
    <div class="hero__bg" style={`background-image:url('${heroImg}')`}></div>

    <span class="hero__corner hero__corner--l">Since {site.established}</span>
    <span class="hero__corner hero__corner--r">Member of<br />Star Wine List</span>

    <div class="container hero__content">
      <p class="hero__eyebrow">Portugal’s first Master of Port</p>
      <p class="hero__credential">The world’s highest Port wine credential, held by only a handful of experts globally</p>
      <h1 class="hero__title">Wine Bar<br />Dogma</h1>
      <p class="hero__sub">{site.tagline}</p>
      <div class="hero__cta">
        <a class="btn btn--cream" href={site.booking.tasting}>Book a tasting</a>
        <a class="btn btn--ghost" href={site.booking.table}>Book a table</a>
      </div>
    </div>

    <a class="hero__scroll" href="#intro" aria-label="Scroll to content">↓</a>
  </section>

  <!-- ───────────────────────── INTRO ───────────────────────── -->
  <section class="section intro" id="intro">
    <div class="container intro__inner">
      <p class="eyebrow eyebrow--ink">The house</p>
      <h2 class="intro__title">A wine paradise in the heart of Porto.</h2>
      <p class="lead">
        Since 2023, Dogma has become one of the city’s most talked-about wine bars — a place to slow
        down, taste widely, and let the terroir speak, every glass poured under the guidance of
        Portugal’s first Master of Port.
      </p>
      <ul class="intro__facts">
        <li>Established 2023</li>
        <li>Member of Star Wine List, 2024–2026</li>
        <li>Featured in <em>O Escanção</em></li>
      </ul>
    </div>
  </section>

  <!-- ──────────────────── MASTER OF PORT (spine) ──────────────────── -->
  <section class="section mop">
    <div class="container mop__inner">
      <div class="mop__seal" aria-hidden="true">
        <svg viewBox="0 0 200 200" role="img">
          <defs>
            <path id="seal-top" d="M100,100 m -70,0 a 70,70 0 1,1 140,0" />
            <path id="seal-bot" d="M100,100 m 70,0 a 70,70 0 1,1 -140,0" />
          </defs>
          <!-- double outer ring -->
          <circle cx="100" cy="100" r="95" fill="none" stroke="currentColor" stroke-width="1.1" />
          <circle cx="100" cy="100" r="89" fill="none" stroke="currentColor" stroke-width="0.5" />
          <!-- circular stamp text -->
          <text class="seal-cap"><textPath href="#seal-top" startOffset="50%" text-anchor="middle">MASTER OF PORT</textPath></text>
          <text class="seal-cap"><textPath href="#seal-bot" startOffset="50%" text-anchor="middle">PORTUGAL · EST. 2023</textPath></text>
          <!-- separator dots where the arcs meet -->
          <circle cx="30" cy="100" r="1.8" fill="currentColor" />
          <circle cx="170" cy="100" r="1.8" fill="currentColor" />
          <!-- inner ring + 8-point star -->
          <circle cx="100" cy="100" r="42" fill="none" stroke="currentColor" stroke-width="0.6" />
          <path
            d="M100,80 L103.25,92.15 L114.14,85.86 L107.85,96.75 L120,100 L107.85,103.25 L114.14,114.14 L103.25,107.85 L100,120 L96.75,107.85 L85.86,114.14 L92.15,103.25 L80,100 L92.15,96.75 L85.86,85.86 L96.75,92.15 Z"
            fill="currentColor"
          />
          <circle cx="100" cy="100" r="1.6" fill="var(--wine-900)" />
        </svg>
      </div>
      <p class="eyebrow">The credential</p>
      <h2 class="mop__title">The first Master of Port in Portugal.</h2>
      <p class="mop__body">
        The Master of Port is the highest distinction awarded for Port wine expertise. Vasilii
        Grebencea is the first in Portugal to hold it — and one of the country’s top three
        sommeliers. It means every tasting at Dogma is led by someone who has reached the very top of
        his craft, and who pours it as a conversation rather than a lecture.
      </p>
      <a class="btn btn--cream" href={site.booking.tasting}>Taste with a Master of Port</a>
    </div>
  </section>

  <!-- ───────────────────────── RECOGNITION ───────────────────────── -->
  <section class="section proud">
    <div class="container">
      <header class="section-head center">
        <p class="eyebrow eyebrow--ink">Recognition</p>
        <h2>A young bar, already noticed.</h2>
      </header>
      <div class="proud__grid">
        <article class="award">
          <p class="award__figure">Top 6</p>
          <p class="award__text">Ranked among the world’s top 6 wine bars as a startup.</p>
        </article>
        <article class="award">
          <p class="award__figure">2×</p>
          <p class="award__text">
            Nominated for Wine Experience of the Year — Great Wine Capitals.
          </p>
        </article>
        <article class="award">
          <p class="award__figure">2024–26</p>
          <p class="award__text">Member of Star Wine List Portugal, three years running.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── SOMMELIER ───────────────────────── -->
  <section class="section somm">
    <div class="container somm__inner">
      <div class="somm__body">
        <p class="eyebrow">Author’s note</p>
        <blockquote class="somm__quote">{sommelier.quote}</blockquote>
        <p class="somm__name">{sommelier.name}</p>
        <p class="somm__role">{sommelier.role}</p>
        <a class="btn btn--cream" href="/sommelier">Meet Vasilii</a>
      </div>

      <!-- Intentional crest in place of a portrait until photography is shot -->
      <figure class="crest" aria-label="Vasilii Grebencea, Master of Port">
        <div class="crest__monogram">VG</div>
        <p class="crest__name">Vasilii Grebencea</p>
        <p class="crest__title">Master of Port · Porto</p>
        <span class="crest__star" aria-hidden="true">✶</span>
      </figure>
    </div>
  </section>

  <!-- ───────────────────────── SERVICES (live only) ───────────────────────── -->
  <section class="section services" id="services">
    <div class="container">
      <header class="section-head center">
        <p class="eyebrow eyebrow--ink">What we offer</p>
        <h2>Two ways to taste.</h2>
      </header>
      <div class="services__grid">
        <article class="svc">
          <h3 class="svc__title">Wine Tasting</h3>
          <p class="svc__text">
            A guided flight through the best of Portugal — five or six wines, the stories behind them,
            and the terroir in the glass.
          </p>
          <p class="svc__price">From €45 · 90 min</p>
          <a class="btn btn--primary" href={site.booking.tasting}>Book a tasting</a>
        </article>
        <article class="svc">
          <h3 class="svc__title">Port Wine Tasting</h3>
          <p class="svc__text">
            A masterclass in Port led by a Master of Port — vintage, tawny and white, with rare
            bottles from the cellar.
          </p>
          <p class="svc__price">From €65 · 120 min</p>
          <a class="btn btn--primary" href={site.booking.tasting}>Book a tasting</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── VISIT ───────────────────────── -->
  <section class="section visit">
    <div class="container visit__inner">
      <div class="visit__col">
        <p class="eyebrow">Visit</p>
        <h2 class="visit__title">Pull up a seat.</h2>
        <p class="visit__addr">
          {site.contact.address}<br />
          {site.contact.postalCode} {site.contact.city}, {site.contact.country}
        </p>
        <a class="visit__maps" href={mapsHref} target="_blank" rel="noopener">Open in Google Maps →</a>
      </div>
      <div class="visit__col">
        <p class="eyebrow">Hours</p>
        <ul class="visit__hours">
          {site.hours.map((h) => (
            <li><span>{h.days}</span><span>{h.time}</span></li>
          ))}
        </ul>
        <p class="visit__phone">
          <a href={site.contact.phoneHref}>{site.contact.phone}</a>
        </p>
        <a class="btn btn--cream" href={site.booking.table}>Book a table</a>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── FINAL CTA ───────────────────────── -->
  <section class="cta">
    <div class="container cta__inner">
      <h2 class="cta__title">Want to learn about wine?</h2>
      <p class="cta__text">
        Spend an evening with Portugal’s first Master of Port. Limited seats at each signature tasting.
      </p>
      <a class="btn btn--cream" href={site.booking.tasting}>Book a tasting</a>
    </div>
  </section>
</Base>

<style>
  /* ───────── HERO ───────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    color: var(--cream-50);
    padding-block: clamp(7rem, 16vh, 11rem) clamp(3rem, 9vh, 5.5rem);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to top,
      rgba(43, 10, 17, 0.9) 0%,
      rgba(43, 10, 17, 0.34) 52%,
      rgba(43, 10, 17, 0.55) 100%
    );
  }
  .hero__corner {
    position: absolute;
    top: clamp(5.5rem, 11vh, 7rem);
    font-size: var(--step--1);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(251, 246, 236, 0.82);
    line-height: 1.35;
  }
  .hero__corner--l { left: var(--gutter); }
  .hero__corner--r { right: var(--gutter); text-align: right; }
  .hero__content { max-width: 900px; }
  .hero__eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--step-0);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-300);
  }
  .hero__credential {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--step-0);
    letter-spacing: 0.02em;
    color: rgba(251, 246, 236, 0.85);
    margin-block: 0.5em 0.3em;
    max-width: 60ch;
  }
  .hero__title {
    font-size: var(--step-4);
    margin-block: 0.18em 0.4em;
    line-height: 0.95;
    text-wrap: balance;
  }
  .hero__sub {
    font-size: var(--step-1);
    max-width: 48ch;
    color: rgba(251, 246, 236, 0.9);
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 2rem; }
  .hero__scroll {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.4rem;
    opacity: 0.7;
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 8px); }
  }

  /* ───────── INTRO ───────── */
  .intro__inner { max-width: 760px; }
  .intro__title { font-size: var(--step-3); margin: 0.4em 0 0.5em; text-wrap: balance; }
  .intro__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.4rem;
    margin-top: 1.8rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .intro__facts li {
    position: relative;
    padding-left: 1.1rem;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }
  .intro__facts li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }
  .intro__facts em { font-style: italic; color: var(--ink); }

  /* ───────── MASTER OF PORT ───────── */
  .mop { background: var(--wine-900); color: var(--cream-50); }
  .mop__inner { max-width: 760px; margin-inline: auto; text-align: center; }
  .mop__seal { width: clamp(124px, 16vw, 168px); margin: 0 auto 1.7rem; color: var(--gold-300); }
  .mop__seal svg { width: 100%; height: auto; }
  .seal-cap {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    fill: currentColor;
  }
  .mop__title { font-size: var(--step-3); margin: 0.35em 0 0.6em; text-wrap: balance; }
  .mop__body {
    font-size: var(--step-1);
    line-height: 1.6;
    color: rgba(251, 246, 236, 0.86);
    max-width: 60ch;
    margin: 0 auto 2rem;
  }

  /* ───────── SECTION HEADS ───────── */
  .section-head { margin-bottom: clamp(2rem, 4vw, 3rem); }
  .section-head h2 { font-size: var(--step-3); margin-top: 0.18em; }

  /* ───────── RECOGNITION ───────── */
  .proud__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.2rem;
  }
  .award {
    padding: 2.2rem 1.9rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-align: center;
  }
  .award__figure {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    line-height: 1;
    color: var(--wine-800);
  }
  .award__text { margin-top: 0.7rem; color: var(--ink-soft); }

  /* ───────── SOMMELIER ───────── */
  .somm { background: var(--wine-900); color: var(--cream-50); }
  .somm__inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .somm__quote {
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.3;
    font-style: italic;
    margin: 0.5rem 0 1.3rem;
    text-wrap: balance;
  }
  .somm__name { font-weight: 600; letter-spacing: 0.02em; }
  .somm__role {
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-300);
    margin-bottom: 1.6rem;
  }
  .crest {
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid rgba(221, 195, 143, 0.5);
    border-radius: var(--radius);
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(221, 195, 143, 0.12), transparent 60%),
      linear-gradient(160deg, var(--wine-700), var(--wine-950));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .crest__monogram {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(4rem, 12vw, 7rem);
    line-height: 1;
    color: var(--gold-300);
    letter-spacing: 0.04em;
  }
  .crest__name { font-weight: 600; letter-spacing: 0.03em; }
  .crest__title {
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(251, 246, 236, 0.72);
  }
  .crest__star { position: absolute; top: 1rem; color: var(--gold-300); font-size: 1.1rem; }
  @media (max-width: 760px) {
    .somm__inner { grid-template-columns: 1fr; }
    .crest { max-width: 320px; margin-inline: auto; width: 100%; }
  }

  /* ───────── SERVICES ───────── */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.4rem;
  }
  .svc {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.7rem;
    padding: 2.3rem 2.1rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .svc:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .svc__title { font-size: var(--step-2); }
  .svc__text { color: var(--ink-soft); flex: 1; }
  .svc__price {
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--wine-800);
  }
  .svc .btn { margin-top: 0.4rem; }

  /* ───────── VISIT ───────── */
  .visit { background: var(--wine-900); color: var(--cream-50); }
  .visit__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
  }
  .visit__title { font-size: var(--step-3); margin: 0.2em 0 0.6em; }
  .visit__addr { font-size: var(--step-1); line-height: 1.5; color: rgba(251, 246, 236, 0.9); }
  .visit__maps {
    display: inline-block;
    margin-top: 1rem;
    color: var(--gold-300);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  .visit__hours { display: grid; gap: 0.5rem; margin-bottom: 1.3rem; }
  .visit__hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(251, 246, 236, 0.14);
    color: rgba(251, 246, 236, 0.9);
  }
  .visit__phone { margin-bottom: 1.5rem; }
  .visit__phone a { border-bottom: 1px solid var(--gold-300); padding-bottom: 2px; }

  /* ───────── FINAL CTA ───────── */
  .cta { background: var(--wine-950); color: var(--cream-50); }
  .cta__inner { text-align: center; max-width: 680px; margin-inline: auto; }
  .cta__title { font-size: var(--step-3); }
  .cta__text { font-size: var(--step-1); color: rgba(251, 246, 236, 0.82); margin: 1rem 0 2rem; }

  @media (max-width: 680px) {
    .hero__corner { display: none; }
    .visit__inner { grid-template-columns: 1fr; }
  }
</style>
