---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";
---

<Base title="Coming Soon" description="This page is coming soon. Check back later or contact us." headerSolid>
  <section class="section coming-soon">
    <div class="container coming-soon__inner">
      <div class="coming-soon__content">
        <h1>Coming Soon</h1>
        <p class="lead">
          We're crafting something special. This page will be available soon.
        </p>
        <p class="description">
          In the meantime, feel free to explore our other pages or get in touch if you have any questions.
        </p>

        <div class="cta-group">
          <a href="/" class="btn btn--cream">Back to Home</a>
          <a href="/contacts" class="btn btn--ghost">Contact Us</a>
        </div>
      </div>

      <div class="coming-soon__decoration">
        <div class="decoration-element">🍇</div>
      </div>
    </div>
  </section>
</Base>

<style>
  .coming-soon {
    background: linear-gradient(160deg, var(--wine-700), var(--wine-950));
    color: var(--cream-50);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .coming-soon__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 4vw, 4rem);
  }

  .coming-soon__content h1 {
    font-size: var(--step-4);
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .coming-soon__content .lead {
    font-size: var(--step-1);
    color: rgba(250, 245, 234, 0.92);
    margin-bottom: 1.2rem;
    max-width: 50ch;
  }

  .coming-soon__content .description {
    font-size: var(--step-0);
    color: rgba(250, 245, 234, 0.78);
    margin-bottom: 2.5rem;
    line-height: 1.7;
    max-width: 50ch;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .coming-soon__decoration {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .decoration-element {
    font-size: 15rem;
    opacity: 0.2;
    line-height: 1;
  }

  @media (max-width: 880px) {
    .coming-soon__inner {
      grid-template-columns: 1fr;
    }

    .decoration-element {
      font-size: 10rem;
    }
  }

  @media (max-width: 520px) {
    .coming-soon {
      min-height: 50vh;
    }

    .coming-soon__content h1 {
      font-size: var(--step-3);
    }

    .cta-group {
      flex-direction: column;
    }

    .cta-group a {
      display: block;
      text-align: center;
    }
  }
</style>
