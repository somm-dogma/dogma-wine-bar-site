---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import { site } from "../data/site";
---

<Base
  title="Message sent"
  description="Thank you for contacting Dogma Wine Bar. We'll be in touch soon."
  headerSolid
>
  <PageHeader eyebrow="Thank you" title="Your message is on its way." />

  <section class="section thanks">
    <div class="container thanks__inner">
      <p class="lead">
        Thank you for reaching out to Dogma. We’ve received your message and will
        get back to you, usually within 24 hours.
      </p>
      <p class="thanks__meta">
        Can’t wait? Call us on
        <a href={site.contact.phoneHref}>{site.contact.phone}</a> during opening hours.
      </p>
      <div class="thanks__cta">
        <a class="btn btn--primary" href="/">Back to home</a>
        <a class="btn btn--ghost" href="/menu">View the menu</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .thanks {
    background: var(--cream-50);
  }
  .thanks__inner {
    max-width: 640px;
  }
  .thanks .lead {
    color: var(--ink);
  }
  .thanks__meta {
    margin-top: 1.2rem;
    color: var(--ink-soft);
  }
  .thanks__meta a {
    color: var(--wine-800);
    border-bottom: 1px solid var(--gold-300);
    padding-bottom: 1px;
  }
  .thanks__meta a:hover {
    color: var(--gold);
  }
  .thanks__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }
  .thanks__cta .btn--ghost {
    color: var(--wine-800);
  }
</style>
