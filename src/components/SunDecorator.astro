---
interface Props {
  size?: "small" | "medium" | "large";
  color?: "gold" | "cream";
}

const { size = "medium", color = "gold" } = Astro.props;

const sizeClass = `sun--${size}`;
const colorClass = color === "cream" ? "sun--cream" : "sun--gold";
---

<svg class:list={["sun", sizeClass, colorClass]} viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
  <circle cx="50" cy="50" r="8" fill="currentColor" />
  <g stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round">
    <line x1="50" y1="5" x2="50" y2="20" />
    <line x1="50" y1="80" x2="50" y2="95" />
    <line x1="5" y1="50" x2="20" y2="50" />
    <line x1="80" y1="50" x2="95" y2="50" />
    <line x1="15" y1="15" x2="27" y2="27" />
    <line x1="73" y1="73" x2="85" y2="85" />
    <line x1="85" y1="15" x2="73" y2="27" />
    <line x1="27" y1="73" x2="15" y2="85" />
  </g>
</svg>

<style>
  .sun {
    display: inline-block;
    color: var(--gold);
  }

  .sun--gold {
    color: var(--gold);
  }

  .sun--cream {
    color: var(--cream-50);
  }

  .sun--small {
    width: 24px;
    height: 24px;
  }

  .sun--medium {
    width: 48px;
    height: 48px;
  }

  .sun--large {
    width: 72px;
    height: 72px;
  }
</style>
