---
interface Props {
  title?: string;
  subtitle?: string;
  imageSrc?: string;
  imageAlt?: string;
  badge?: boolean;
  badgeText?: string;
  badgeYear?: string;
}

const {
  title,
  subtitle,
  imageSrc,
  imageAlt = "Content",
  badge = false,
  badgeText,
  badgeYear
} = Astro.props;
---

<div class="arch-container">
  <!-- Decorative sun top -->
  <svg class="arch__sun arch__sun--top" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <circle cx="50" cy="50" r="8" fill="currentColor" />
    <g stroke="currentColor" stroke-width="2" fill="none">
      <line x1="50" y1="10" x2="50" y2="25" />
      <line x1="50" y1="75" x2="50" y2="90" />
      <line x1="10" y1="50" x2="25" y2="50" />
      <line x1="75" y1="50" x2="90" y2="50" />
      <line x1="20" y1="20" x2="30" y2="30" />
      <line x1="70" y1="70" x2="80" y2="80" />
      <line x1="80" y1="20" x2="70" y2="30" />
      <line x1="30" y1="70" x2="20" y2="80" />
    </g>
  </svg>

  <!-- Main arch border -->
  <div class="arch">
    <!-- Content area -->
    <div class="arch__content">
      {imageSrc && (
        <img src={imageSrc} alt={imageAlt} class="arch__image" />
      )}

      {badge && (
        <div class="arch__badge">
          <svg class="arch__star" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="6" fill="currentColor" />
            <g stroke="currentColor" stroke-width="1.5" fill="none">
              <line x1="50" y1="15" x2="50" y2="25" />
              <line x1="50" y1="75" x2="50" y2="85" />
              <line x1="15" y1="50" x2="25" y2="50" />
              <line x1="75" y1="50" x2="85" y2="50" />
              <line x1="25" y1="25" x2="32" y2="32" />
              <line x1="68" y1="68" x2="75" y2="75" />
              <line x1="75" y1="25" x2="68" y2="32" />
              <line x1="32" y1="68" x2="25" y2="75" />
            </g>
          </svg>

          {badgeText && <p class="arch__badge-text">{badgeText}</p>}
          {badgeYear && <p class="arch__badge-year">{badgeYear}</p>}
        </div>
      )}

      {title && <h3 class="arch__title">{title}</h3>}
      {subtitle && <p class="arch__subtitle">{subtitle}</p>}
    </div>

    <!-- Arch border (bottom point) -->
    <div class="arch__point"></div>
  </div>

  <!-- Decorative suns bottom left -->
  <svg class="arch__sun arch__sun--bottom-left" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <circle cx="50" cy="50" r="6" fill="currentColor" />
    <g stroke="currentColor" stroke-width="1.5" fill="none">
      <line x1="50" y1="10" x2="50" y2="22" />
      <line x1="50" y1="78" x2="50" y2="90" />
      <line x1="10" y1="50" x2="22" y2="50" />
      <line x1="78" y1="50" x2="90" y2="50" />
    </g>
  </svg>

  <!-- Decorative suns bottom right -->
  <svg class="arch__sun arch__sun--bottom-right" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <circle cx="50" cy="50" r="6" fill="currentColor" />
    <g stroke="currentColor" stroke-width="1.5" fill="none">
      <line x1="50" y1="10" x2="50" y2="22" />
      <line x1="50" y1="78" x2="50" y2="90" />
      <line x1="10" y1="50" x2="22" y2="50" />
      <line x1="78" y1="50" x2="90" y2="50" />
    </g>
  </svg>
</div>

<style>
  .arch-container {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* Decorative suns */
  .arch__sun {
    width: clamp(30px, 8vw, 60px);
    height: clamp(30px, 8vw, 60px);
    color: var(--gold);
    margin-bottom: clamp(0.5rem, 2vh, 1rem);
  }

  .arch__sun--bottom-left,
  .arch__sun--bottom-right {
    position: absolute;
    width: clamp(20px, 5vw, 40px);
    height: clamp(20px, 5vw, 40px);
    color: rgba(201, 169, 97, 0.6);
  }

  .arch__sun--bottom-left {
    bottom: clamp(-1rem, -3vh, 0);
    left: clamp(1rem, 5vw, 2rem);
  }

  .arch__sun--bottom-right {
    bottom: clamp(-1rem, -3vh, 0);
    right: clamp(1rem, 5vw, 2rem);
  }

  /* Main arch element */
  .arch {
    position: relative;
    width: 100%;
    max-width: 280px;
    aspect-ratio: 3 / 4;
    border: 3px solid var(--cream-50);
    border-radius: 40px 40px 30% 30%;
    background: rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: inset 0 0 30px rgba(0, 0, 0, 0.2);
  }

  /* Point at bottom (wine glass style) */
  .arch__point {
    position: absolute;
    bottom: -20px;
    width: 0;
    height: 0;
    border-left: 20px solid transparent;
    border-right: 20px solid transparent;
    border-top: 20px solid var(--cream-50);
  }

  /* Content inside arch */
  .arch__content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 3vw, 1.5rem);
    text-align: center;
  }

  /* Image inside arch */
  .arch__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 35px 35px 25% 25%;
  }

  /* Badge styling */
  .arch__badge {
    position: absolute;
    top: -15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .arch__star {
    width: 40px;
    height: 40px;
    color: var(--cream-50);
  }

  .arch__badge-text {
    font-family: var(--font-body);
    font-size: clamp(0.7rem, 1.5vw, 0.85rem);
    font-weight: 600;
    color: var(--cream-50);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.2;
  }

  .arch__badge-year {
    font-family: var(--font-display);
    font-size: clamp(0.85rem, 2vw, 1rem);
    color: var(--cream-50);
    font-weight: 500;
  }

  /* Text inside arch (for non-image content) */
  .arch__title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    color: var(--cream-50);
    font-weight: 600;
    margin: 0;
    line-height: 1.2;
  }

  .arch__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.5vw, 0.95rem);
    color: rgba(250, 245, 234, 0.8);
    margin-top: 0.5rem;
    margin: 0;
  }

  /* Responsive adjustments */
  @media (max-width: 760px) {
    .arch {
      max-width: 200px;
    }

    .arch__sun--bottom-left,
    .arch__sun--bottom-right {
      display: none;
    }
  }
</style>
