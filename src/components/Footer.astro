---
import { Image } from "astro:assets";
import { site, nav } from "../data/site";
import taCert from "../assets/images/tripadvisor-travellers-choice-2025.png";
const year = new Date().getFullYear();

const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
  `${site.contact.address}, ${site.contact.postalCode} ${site.contact.city}`
)}`;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="brand">Dogma</p>
      <p class="footer-tag">{site.tagline}</p>

      <a
        class="ta-badge"
        href="/certificates/tripadvisor-travellers-choice-2025.pdf"
        target="_blank"
        rel="noopener"
        aria-label="Tripadvisor Travellers' Choice Awards 2025 — Top 10% worldwide. Opens the certificate PDF in a new tab."
      >
        <Image
          src={taCert}
          alt="Tripadvisor Travellers' Choice Awards 2025 certificate for Dogma Wine Bar"
          class="ta-badge__img"
          widths={[160, 320]}
          sizes="150px"
        />
        <span class="ta-badge__meta">
          <span class="ta-badge__title">Travellers’ Choice 2025</span>
          <span class="ta-badge__sub">Tripadvisor · Top 10% worldwide</span>
        </span>
      </a>
    </div>

    <nav class="footer-col" aria-label="Footer navigation">
      <h4 class="footer-h">Explore</h4>
      <ul class="footer-list">
        {nav.map((i) => <li><a href={i.href}>{i.label}</a></li>)}
        <li><a href="/privacy">Privacy</a></li>
      </ul>
    </nav>

    <div class="footer-col">
      <h4 class="footer-h">Reach us</h4>
      <ul class="footer-list">
        <li><a href={mapsHref} target="_blank" rel="noopener">{site.contact.address}, {site.contact.city}</a></li>
        <li><a href={site.contact.phoneHref}>{site.contact.phone}</a></li>
        {site.contact.email && (
          <li><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></li>
        )}
        {site.social.instagram && (
          <li><a href={site.social.instagram} target="_blank" rel="noopener">{site.social.instagramHandle ?? "Instagram"}</a></li>
        )}
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {site.name}. All rights reserved.</p>
    <p>Design by <a href={site.credits.designerUrl} target="_blank" rel="noopener">{site.credits.designer}</a></p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--wine-950);
    color: var(--cream-50);
    padding-top: clamp(3rem, 6vw, 5rem);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .footer-brand .brand {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }
  .footer-tag {
    margin-top: 0.9rem;
    max-width: 30ch;
    color: rgba(251, 246, 236, 0.7);
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: 1.35;
  }
  .footer-h {
    font-family: var(--font-body);
    font-size: var(--step--1);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-300);
    margin-bottom: 1.1rem;
  }
  .footer-list { display: grid; gap: 0.6rem; }
  .footer-list a {
    color: rgba(251, 246, 236, 0.82);
    transition: color 0.2s ease;
  }
  .footer-list a:hover { color: var(--gold-300); }

  /* Tripadvisor Travellers' Choice — framed, clickable certificate */
  .ta-badge {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.8rem;
    padding: 0.7rem 0.9rem;
    background: var(--paper);
    border-radius: 12px;
    box-shadow: var(--shadow-md);
    transition: transform var(--dur-mid) var(--ease-out), box-shadow var(--dur-mid) var(--ease-out);
  }
  .ta-badge:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .ta-badge__img {
    width: 64px;
    height: auto;
    border-radius: 6px;
    flex: 0 0 auto;
  }
  .ta-badge__meta { display: grid; gap: 0.15rem; }
  .ta-badge__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-0);
    line-height: 1.1;
    color: var(--wine-900);
  }
  .ta-badge__sub {
    font-family: var(--font-body);
    font-size: var(--step--1);
    color: var(--ink-soft);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.6rem;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(251, 246, 236, 0.12);
    font-size: var(--step--1);
    color: rgba(251, 246, 236, 0.55);
  }
  .footer-bottom a { color: var(--gold-300); }
  .footer-bottom a:hover { color: var(--cream-50); }

  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 460px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
